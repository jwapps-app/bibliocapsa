# Bibliocapsa — environment configuration
# Copy this to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────────
# Path to your Calibre library folder on the host machine
CALIBRE_LIBRARY_PATH=/path/to/your/calibre/library

# ── Optional ──────────────────────────────────────────────────────────────────
# API port (default 8000)
PORT=8000

# Web UI port (default 3001 — change if 3001 is taken)
WEB_PORT=3001

# PostgreSQL password — REQUIRED: set this to a long, random value.
# (The database isn't exposed outside the Docker network, but don't ship the default.)
POSTGRES_PASSWORD=change-me-to-a-long-random-password

# Session-cookie Secure flag. "auto" (recommended) marks it Secure only when the
# request arrives over HTTPS — so HTTPS users are hardened and plain-http LAN users
# aren't locked out. Use "true"/"false" only to force it.
COOKIE_SECURE=auto

# CORS allowed origins. Leave EMPTY for the normal same-origin setup (the web UI
# proxies to the API). Only set this (comma-separated origins) if a separate
# front-end on another domain needs cross-origin access. Never use "*".
ALLOWED_ORIGINS=

# ── Cloudflare Tunnel (optional) ──────────────────────────────────────────────
# Uncomment and set to enable remote access without port forwarding
# CLOUDFLARE_TUNNEL_TOKEN=your_token_here
