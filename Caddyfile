# Single entrypoint for Bibliocapsa. Routes the API / OPDS / WebDAV / KOSync
# paths to the backend and everything else to the web UI — so the whole app is
# reachable on ONE port (and one Cloudflare route). A real reverse proxy here
# also forwards WebDAV methods (PROPFIND/MKCOL/PUT) correctly, which the Next.js
# rewrite layer does not.
:80 {
	# Baseline security headers (TLS/HSTS is owned by the upstream — Cloudflare or
	# your own reverse proxy — since this listens on plain :80 behind it).
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
		# CSP tuned for this app: Next.js + the in-browser epub.js / pdf.js readers
		# (which need eval, web workers, and blob: URLs) and the pervasive inline
		# styles. Book HTML is separately DOMPurify-sanitized. frame-ancestors 'none'
		# is the modern clickjacking guard.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; worker-src 'self' blob:; frame-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
		-Server
	}

	@backend path /api/* /opds /opds/* /dav /dav/* /users/* /syncs/* /healthcheck
	handle @backend {
		reverse_proxy bibliocapsa:8000
	}
	handle {
		reverse_proxy web:3000
	}
}
